{
  "name": "@d31ma/fylo",
  "version": "3.0.0",
  "main": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "fylo.query": "./dist/cli/index.js",
    "fylo.admin": "./dist/cli/index.js",
    "fylo.exec": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:exe": "mkdir -p ./dist/bin && bun build --compile ./src/cli/index.js --outfile ./dist/bin/fylo",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" README.md",
    "format": "prettier --write src tests"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@d31ma/chex": "0.4.1",
    "@d31ma/ttid": "1.3.7"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d31ma/Fylo.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "homepage": "https://fylo.del.ma",
  "license": "MIT",
  "keywords": [
    "storage",
    "database",
    "filesystem",
    "document-store",
    "javascript",
    "jsdoc",
    "executable",
    "bun"
  ],
  "author": "Chidelma",
  "bugs": {
    "url": "https://github.com/d31ma/Fylo/issues"
  }
}
